---
/**
 * @component SearchModal
 * @description 全局搜索弹窗（客户端过滤）。
 *
 * 使用方式：
 *  - 在 Layout.astro 全局挂载一次即可。
 *  - 打开：#search-open-btn 点击 或 Ctrl/Cmd+K。
 *  - 关闭：点击遮罩、按 Escape、或点击 ✕ 按钮。
 *
 * 数据来源：懒加载 /api/posts.json（构建时生成）。
 */
---

<!-- 遮罩 + 弹窗容器 -->
<div
  id="search-modal"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-label="搜索文章"
  class="hidden fixed inset-0 z-50 flex items-start justify-center pt-[10vh] px-4"
>
  <!-- 半透明遮罩 -->
  <div
    id="search-backdrop"
    class="absolute inset-0 bg-void-950/80 backdrop-blur-sm"
    aria-hidden="true"
  ></div>

  <!-- 弹窗主体 -->
  <div
    class="relative w-full max-w-xl glass-card animate-scale-in overflow-hidden"
    role="document"
  >
    <!-- 搜索输入框 -->
    <div class="flex items-center gap-3 px-4 py-3 border-b border-white/8">
      <svg class="w-4 h-4 text-lavender-400 shrink-0" fill="none" stroke="currentColor"
           stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <!-- sr-only label：屏幕阅读器能读到“搜索关键词”，视觉用户看到 placeholder 即可 -->
      <label for="search-input" class="sr-only">搜索关键词</label>
      <input
        id="search-input"
        type="search"
        placeholder="搜索文章标题、标签……"
        autocomplete="off"
        class="flex-1 bg-transparent text-lavender-100 placeholder-lavender-600
               text-sm focus:outline-none"
      />
      <!-- 关闭按钮 -->
      <button
        id="search-close-btn"
        type="button"
        aria-label="关闭搜索"
        class="p-1 rounded-lg text-lavender-500 hover:text-white
               hover:bg-white/8 transition-colors shrink-0 cursor-pointer"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"
             viewBox="0 0 24 24" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- 搜索结果列表 -->
    <ul
      id="search-results"
      role="listbox"
      class="max-h-80 overflow-y-auto py-2"
      aria-label="搜索结果"
    >
      <!-- 初始状态提示 -->
      <li id="search-hint" class="px-4 py-8 text-center text-sm text-lavender-500" aria-live="polite">
        输入关键词开始搜索
      </li>
    </ul>

    <!-- 快捷键提示 -->
    <div class="px-4 py-2 border-t border-white/6 flex items-center gap-3 text-xs text-lavender-600">
      <span><kbd class="font-mono bg-white/8 px-1.5 py-0.5 rounded">↑↓</kbd> 导航</span>
      <span><kbd class="font-mono bg-white/8 px-1.5 py-0.5 rounded">Enter</kbd> 打开</span>
      <span><kbd class="font-mono bg-white/8 px-1.5 py-0.5 rounded">Esc</kbd> 关闭</span>
    </div>
  </div>
</div>

<script>
  import { isSearchEntry, type SearchEntry } from '../types';
  import { LIMITS } from '../config/site';

  // ── DOM refs（全部断言非 null：缺任一个都是模板 bug，早崩比静默错好） ──
  const modal      = document.getElementById('search-modal')!;
  const backdrop   = document.getElementById('search-backdrop')!;
  const input      = document.getElementById('search-input') as HTMLInputElement;
  const resultList = document.getElementById('search-results')!;
  const hint       = document.getElementById('search-hint')!;
  const closeBtn   = document.getElementById('search-close-btn')!;

  // ── State ──────────────────────────────────────────────────────────
  let allPosts: SearchEntry[] = [];
  let fetched = false;
  let selectedIdx = -1;

  // ── Fetch index (lazy, once) ───────────────────────────────────────
  async function ensureIndex(): Promise<void> {
    if (fetched) return;
    fetched = true;
    try {
      const res = await fetch('/api/posts.json');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const raw: unknown = await res.json();
      if (!Array.isArray(raw)) {
        throw new Error('搜索索引格式错误：期望数组');
      }
      // 逐项校验：字段缺失/类型不匹配的条目直接丢弃，不让整个搜索挂掉
      allPosts = raw.filter(isSearchEntry);

      if (allPosts.length === 0 && raw.length > 0) {
        hint.textContent = '搜索索引异常，请联系管理员';
      }
    } catch (err) {
      // 失败后下次打开允许重试
      fetched = false;
      hint.textContent = '加载失败，请刷新重试';
      console.error('[SearchModal] fetch index failed:', err);
    }
  }

  // ── Open / close ───────────────────────────────────────────────────
  function openModal() {
    modal.classList.remove('hidden');
    modal.setAttribute('aria-hidden', 'false');
    input.value = '';
    renderResults([]);
    hint.hidden = false;
    selectedIdx = -1;
    ensureIndex();
    requestAnimationFrame(() => input.focus());
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.setAttribute('aria-hidden', 'true');
    input.value = '';
  }

  // 监听 NavBar 派发的自定义事件（避免跨组件直接耦合）
  document.addEventListener('search:open', openModal);

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // ── Search & render ────────────────────────────────────────────────
  function search(query: string): SearchEntry[] {
    const q = query.trim().toLowerCase();
    if (!q) return [];
    return allPosts.filter(
      (p) =>
        p.title.toLowerCase().includes(q) ||
        p.description.toLowerCase().includes(q) ||
        p.tags.some((t) => t.toLowerCase().includes(q)) ||
        p.category.some((c) => c.toLowerCase().includes(q)),
    ).slice(0, LIMITS.searchResults);
  }

  function renderResults(results: SearchEntry[]) {
    hint.hidden = true;
    selectedIdx = -1;

    // 清空旧结果：role="option" 的搜索结果项 + search-empty 的空状态提示
    resultList.querySelectorAll('[role="option"], .search-empty').forEach((el) => el.remove());

    if (results.length === 0) {
      if (input.value.trim()) {
        const li = document.createElement('li');
        li.className = 'search-empty px-4 py-8 text-center text-sm text-lavender-500';
        li.textContent = '未找到相关文章';
        resultList.appendChild(li);
      } else {
        hint.hidden = false;
      }
      return;
    }

    // 小工具：构造带 class 的元素 + 文本（用 textContent，彻底杜绝 HTML 注入）
    const el = <K extends keyof HTMLElementTagNameMap>(
      tag: K, cls: string, text?: string,
    ): HTMLElementTagNameMap[K] => {
      const node = document.createElement(tag);
      node.className = cls;
      if (text !== undefined) node.textContent = text;
      return node;
    };

    results.forEach((post, idx) => {
      const li = document.createElement('li');
      li.setAttribute('role', 'option');
      li.setAttribute('aria-selected', 'false');
      li.dataset.idx = String(idx);
      li.className =
        'flex items-start gap-3 px-4 py-3 cursor-pointer rounded-lg mx-2 transition-colors duration-150';

      const date = new Date(post.pubDate).toLocaleDateString('zh-CN', {
        year: 'numeric', month: 'short', day: 'numeric',
      });

      // 文本节点：所有字符串都走 textContent，避免 frontmatter 里潜藏 HTML 被执行
      const textWrap = el('div', 'flex-1 min-w-0');
      textWrap.appendChild(el('p', 'text-sm font-medium text-lavender-100 truncate', post.title));
      textWrap.appendChild(el('p', 'text-xs text-lavender-500 truncate mt-0.5', post.description));
      textWrap.appendChild(
        el('p', 'text-xs text-lavender-600 mt-1', `${post.category.join(' / ')} · ${date}`),
      );
      li.appendChild(textWrap);

      // 右侧箭头：SVG 走 innerHTML 是安全的 —— 这段是代码里写死的字面量，不拼接任何变量
      const arrow = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      arrow.setAttribute('class', 'w-4 h-4 text-lavender-600 shrink-0 mt-0.5');
      arrow.setAttribute('fill', 'none');
      arrow.setAttribute('stroke', 'currentColor');
      arrow.setAttribute('stroke-width', '2');
      arrow.setAttribute('viewBox', '0 0 24 24');
      arrow.setAttribute('aria-hidden', 'true');
      arrow.innerHTML = '<path d="m9 18 6-6-6-6"/>';
      li.appendChild(arrow);

      li.addEventListener('click', () => {
        window.location.href = `/blog/${post.slug}`;
        closeModal();
      });

      li.addEventListener('mouseenter', () => setSelected(idx));

      resultList.appendChild(li);
    });
  }

  // ── Keyboard navigation ────────────────────────────────────────────
  function setSelected(idx: number) {
    const items = resultList.querySelectorAll<HTMLElement>('[role="option"]');
    items.forEach((el, i) => {
      const active = i === idx;
      el.setAttribute('aria-selected', String(active));
      el.classList.toggle('bg-sakura-500/10', active);
      el.classList.toggle('text-white', active);
    });
    selectedIdx = idx;
  }

  input.addEventListener('keydown', (e) => {
    const items = resultList.querySelectorAll<HTMLElement>('[role="option"]');
    if (!items.length) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setSelected(Math.min(selectedIdx + 1, items.length - 1));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setSelected(Math.max(selectedIdx - 1, 0));
    } else if (e.key === 'Enter' && selectedIdx >= 0) {
      items[selectedIdx]?.click();
    }
  });

  // ── Debounced input handler ────────────────────────────────────────
  let debounceTimer: ReturnType<typeof setTimeout>;

  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      renderResults(search(input.value));
    }, 150);
  });
</script>
