---
/**
 * @component Sidebar
 * @description 侧边栏，包含个人卡片、分类列表、近期文章、标签云。
 *              接收聚合数据由父页面（首页/列表页）计算后传入，避免重复查询。
 */

import type { SidebarData } from '../types';
import { SITE, LIMITS } from '../config/site';
import { tagFontSizePx } from '../utils/ui';
import { fmtMonthDayCN } from '../utils/date';

type Props = SidebarData;

const { allTags, tagCounts, recentPosts, categories, totalPosts } =
  Astro.props;

// 标签云展示上限：tagCloudMax=0 时不截断。按 tagCounts 降序取前 N，避免侧边
// 太长的标签列表把「最近发布」挤到视口外
const tagsForCloud = LIMITS.tagCloudMax > 0
  ? [...allTags]
      .sort((a, b) => (tagCounts[b] ?? 0) - (tagCounts[a] ?? 0))
      .slice(0, LIMITS.tagCloudMax)
  : allTags;
---

<aside class="space-y-5 lg:w-72 shrink-0" aria-label="侧边栏">

  <!-- ── 个人卡片 ──────────────────────────────────────── -->
  <div class="glass-card p-6 flex flex-col items-center text-center gap-3">

    <!-- 头像（带发光环） -->
    <div class="relative">
      <div class="w-20 h-20 rounded-full p-0.5 bg-gradient-brand animate-float shadow-glow-pink">
        <img
          src={SITE.avatar}
          alt={`${SITE.author} 的头像`}
          class="w-full h-full rounded-full object-cover"
          width="80"
          height="80"
          loading="eager"
          decoding="async"
        />
      </div>
      <!-- 在线状态点 -->
      <span
        class="absolute bottom-0.5 right-0.5 w-3.5 h-3.5 bg-mint-400
               border-2 border-void-800 rounded-full"
        aria-label="在线"
      ></span>
    </div>

    <!-- 名字 + 简介 -->
    <div>
      <h3 class="font-heading font-semibold text-lavender-100">{SITE.author}</h3>
      <p class="text-xs text-lavender-500 mt-0.5">代码 · 读书 · 备考</p>
    </div>
    <p class="text-xs text-lavender-400 leading-relaxed">{SITE.bio}</p>

    <!-- 统计行 -->
    <div class="flex gap-4 text-center w-full border-t border-white/6 pt-3">
      {[
        { value: totalPosts,                     label: '文章' },
        { value: allTags.length,                 label: '标签' },
        { value: Object.keys(categories).length, label: '分类' },
      ].map(({ value, label }) => (
        <div class="flex-1">
          <div class="font-semibold text-sakura-400 text-sm">{value}</div>
          <div class="text-xs text-lavender-600">{label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- ── 分类列表 ──────────────────────────────────────── -->
  <div class="glass-card p-5">
    <h4 class="section-heading font-heading text-sm font-semibold text-lavender-200">
      分类
    </h4>
    <ul class="space-y-1">
      {Object.entries(categories).map(([cat, count]) => (
        <li>
          <a
            href={`/categories#cat-${encodeURIComponent(cat)}`}
            class="flex items-center justify-between px-3 py-1.5 rounded-xl text-sm
                   text-lavender-400 hover:text-lavender-100 hover:bg-white/5
                   transition-all duration-200"
          >
            <span>{cat}</span>
            <span class="text-xs bg-sakura-500/15 text-sakura-400 rounded-full px-2 py-0.5">
              {count}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- ── 最近发布 ──────────────────────────────────────── -->
  <div class="glass-card p-5">
    <h4 class="section-heading font-heading text-sm font-semibold text-lavender-200">
      最近发布
    </h4>
    <ul class="space-y-3">
      {recentPosts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}`} class="group flex flex-col gap-0.5">
            <span class="text-sm text-lavender-300 group-hover:text-sakura-300
                         transition-colors line-clamp-1 font-medium">
              {post.title}
            </span>
            <time
              datetime={post.pubDate.toISOString()}
              class="text-xs text-lavender-600"
            >
              {fmtMonthDayCN(post.pubDate)}
            </time>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- ── 标签云 ────────────────────────────────────────── -->
  <div class="glass-card p-5">
    <h4 class="section-heading font-heading text-sm font-semibold text-lavender-200">
      标签云
    </h4>
    <div class="flex flex-wrap gap-2">
      {tagsForCloud.map((tag) => (
        <a
          href={`/tags/${encodeURIComponent(tag)}`}
          class="tag-pill"
          style={`font-size: ${tagFontSizePx(tagCounts[tag] ?? 1)}`}
        >
          {tag}
          <span class="text-sakura-600/70">{tagCounts[tag]}</span>
        </a>
      ))}
    </div>
  </div>

</aside>
