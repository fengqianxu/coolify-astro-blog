<!-- Cheerful floating petals + sparkle particles on light background -->
<canvas id="starfield" class="fixed inset-0 pointer-events-none z-0" aria-hidden="true"></canvas>

<script>
  const canvas = document.getElementById('starfield') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;
  let W = 0, H = 0;

  interface Sparkle { x: number; y: number; r: number; o: number; d: number; hue: number; }
  interface Petal   { x: number; y: number; r: number; vx: number; vy: number; rot: number; vr: number; o: number; color: string; }

  const sparkles: Sparkle[] = [];
  const petals:   Petal[]   = [];

  const petalColors = [
    'rgba(255,186,214,VAL)',   // soft pink
    'rgba(255,209,230,VAL)',   // light pink
    'rgba(196,181,253,VAL)',   // lavender
    'rgba(253,186,116,VAL)',   // peach
    'rgba(110,231,183,VAL)',   // mint
  ];

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }

  function initSparkles() {
    sparkles.length = 0;
    const count = Math.floor((W * H) / 10000);
    for (let i = 0; i < count; i++) {
      sparkles.push({
        x:   Math.random() * W,
        y:   Math.random() * H,
        r:   Math.random() * 3 + 1,
        o:   Math.random(),
        d:   (Math.random() - 0.5) * 0.015,
        hue: Math.random() * 60 - 30, // pink to lavender range
      });
    }
    petals.length = 0;
    for (let i = 0; i < 22; i++) petals.push(spawnPetal(true));
  }

  function spawnPetal(anywhere = false): Petal {
    const color = petalColors[Math.floor(Math.random() * petalColors.length)]!;
    return {
      x:   Math.random() * W,
      y:   anywhere ? Math.random() * H : -20,
      r:   Math.random() * 6 + 4,
      vx:  (Math.random() - 0.5) * 0.7,
      vy:  Math.random() * 0.8 + 0.3,
      rot: Math.random() * Math.PI * 2,
      vr:  (Math.random() - 0.5) * 0.04,
      o:   Math.random() * 0.5 + 0.25,
      color,
    };
  }

  function drawSparkle(s: Sparkle) {
    const size = s.r;
    ctx.save();
    ctx.translate(s.x, s.y);
    ctx.globalAlpha = s.o * 0.6;
    // 4-point star shape
    ctx.beginPath();
    for (let i = 0; i < 4; i++) {
      const angle = (i / 4) * Math.PI * 2;
      const inner = size * 0.3;
      ctx.lineTo(Math.cos(angle) * size,         Math.sin(angle) * size);
      ctx.lineTo(Math.cos(angle + Math.PI/4) * inner, Math.sin(angle + Math.PI/4) * inner);
    }
    ctx.closePath();
    // Warm gold / pink sparkle color
    ctx.fillStyle = `hsl(${340 + s.hue}, 80%, 75%)`;
    ctx.fill();
    ctx.restore();
  }

  function drawPetal(p: Petal) {
    ctx.save();
    ctx.translate(p.x, p.y);
    ctx.rotate(p.rot);
    ctx.globalAlpha = p.o;
    ctx.beginPath();
    ctx.ellipse(0, 0, p.r, p.r * 0.55, 0, 0, Math.PI * 2);
    ctx.fillStyle = p.color.replace('VAL', p.o.toFixed(2));
    ctx.fill();
    // Soft petal highlight
    ctx.beginPath();
    ctx.ellipse(-p.r * 0.2, -p.r * 0.2, p.r * 0.4, p.r * 0.2, -0.5, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.fill();
    ctx.restore();
  }

  let frame = 0;
  function tick() {
    ctx.clearRect(0, 0, W, H);

    for (const s of sparkles) {
      s.o += s.d;
      if (s.o <= 0.05 || s.o >= 0.9) s.d *= -1;
      drawSparkle(s);
    }

    for (let i = petals.length - 1; i >= 0; i--) {
      const p = petals[i]!;
      p.x  += p.vx + Math.sin(frame * 0.012 + i) * 0.4;
      p.y  += p.vy;
      p.rot += p.vr;
      drawPetal(p);
      if (p.y > H + 30) petals.splice(i, 1, spawnPetal());
    }

    frame++;
    requestAnimationFrame(tick);
  }

  resize();
  initSparkles();
  tick();

  window.addEventListener('resize', () => { resize(); initSparkles(); }, { passive: true });
</script>
