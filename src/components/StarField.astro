---
/**
 * @component StarField
 * @description 固定背景 Canvas —— 暗紫主题下的星光 + 樱花花瓣粒子。
 *              pointer-events-none，不干扰任何交互。
 *
 * 粒子系统设计：
 *  - Sparkle：4 角星形，随机分布，缓慢闪烁（opacity 振荡）
 *  - Petal  ：椭圆形花瓣，从顶部生成后缓慢飘落，带轻微横向摇摆
 */
---

<canvas
  id="starfield"
  class="fixed inset-0 pointer-events-none z-0"
  aria-hidden="true"
></canvas>

<script>
  // ── 类型定义 ──────────────────────────────────────────────────────
  interface Sparkle {
    x: number; y: number;
    r: number;          // 外半径
    opacity: number;
    dOpacity: number;   // 每帧 opacity 变化量
    hue: number;        // 色相偏移（粉→紫）
  }

  interface Petal {
    x: number; y: number;
    r: number;          // 椭圆长轴
    vx: number; vy: number;
    rot: number; vRot: number;
    opacity: number;
    colorIdx: number;   // 花瓣颜色索引
  }

  // ── 花瓣颜色表（RGBA 模板，VAL 替换为实际 opacity） ───────────────
  const PETAL_COLORS = [
    'rgba(244,114,182,VAL)',  // sakura-400
    'rgba(249,168,212,VAL)',  // sakura-300
    'rgba(196,181,253,VAL)',  // lavender-300
    'rgba(251,191,36,VAL)',   // gold-400（少量）
    'rgba(167,139,250,VAL)',  // lavender-400
  ] as const;

  // ── Canvas 初始化 ─────────────────────────────────────────────────
  const canvas = document.getElementById('starfield') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;

  let W = 0, H = 0;
  let sparkles: Sparkle[] = [];
  let petals:   Petal[]   = [];
  let frameId   = 0;
  let frameCount = 0;

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }

  // ── 粒子工厂 ─────────────────────────────────────────────────────
  function createSparkle(): Sparkle {
    return {
      x:        Math.random() * W,
      y:        Math.random() * H,
      r:        Math.random() * 1.5 + 0.5,
      opacity:  Math.random(),
      dOpacity: (Math.random() * 0.008 + 0.004) * (Math.random() < 0.5 ? 1 : -1),
      hue:      Math.random() * 60 - 30, // -30 ~ +30（粉到紫区间）
    };
  }

  function createPetal(anywhere = false): Petal {
    return {
      x:        Math.random() * W,
      y:        anywhere ? Math.random() * H : -20,
      r:        Math.random() * 5 + 4,
      vx:       (Math.random() - 0.5) * 0.6,
      vy:       Math.random() * 0.7 + 0.25,
      rot:      Math.random() * Math.PI * 2,
      vRot:     (Math.random() - 0.5) * 0.035,
      opacity:  Math.random() * 0.45 + 0.15,
      colorIdx: Math.floor(Math.random() * PETAL_COLORS.length),
    };
  }

  function initParticles() {
    const sparkleCount = Math.floor((W * H) / 8000);
    sparkles = Array.from({ length: sparkleCount }, createSparkle);
    petals   = Array.from({ length: 20 },           () => createPetal(true));
  }

  // ── 绘制函数 ──────────────────────────────────────────────────────
  function drawSparkle(s: Sparkle) {
    ctx.save();
    ctx.translate(s.x, s.y);
    ctx.globalAlpha = Math.max(0, s.opacity) * 0.7;
    // 4 角星形（对角两组线）
    ctx.beginPath();
    for (let i = 0; i < 4; i++) {
      const a = (i / 4) * Math.PI * 2;
      const b = a + Math.PI / 4;
      ctx.lineTo(Math.cos(a) * s.r,         Math.sin(a) * s.r);
      ctx.lineTo(Math.cos(b) * (s.r * 0.3), Math.sin(b) * (s.r * 0.3));
    }
    ctx.closePath();
    ctx.fillStyle = `hsl(${340 + s.hue}, 75%, 80%)`;
    ctx.fill();
    ctx.restore();
  }

  function drawPetal(p: Petal) {
    ctx.save();
    ctx.translate(p.x, p.y);
    ctx.rotate(p.rot);
    ctx.globalAlpha = p.opacity;

    // 花瓣主体
    ctx.beginPath();
    ctx.ellipse(0, 0, p.r, p.r * 0.5, 0, 0, Math.PI * 2);
    ctx.fillStyle = PETAL_COLORS[p.colorIdx]!.replace('VAL', p.opacity.toFixed(2));
    ctx.fill();

    // 高光（增加立体感）
    ctx.beginPath();
    ctx.ellipse(-p.r * 0.25, -p.r * 0.15, p.r * 0.35, p.r * 0.15, -0.4, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.fill();

    ctx.restore();
  }

  // ── 动画主循环 ────────────────────────────────────────────────────
  function tick() {
    ctx.clearRect(0, 0, W, H);

    // 更新并绘制闪光
    for (const s of sparkles) {
      s.opacity += s.dOpacity;
      if (s.opacity <= 0.05 || s.opacity >= 0.95) s.dOpacity *= -1;
      drawSparkle(s);
    }

    // 更新并绘制花瓣
    for (let i = petals.length - 1; i >= 0; i--) {
      const p = petals[i]!;
      // 轻微正弦横向摇摆
      p.x   += p.vx + Math.sin(frameCount * 0.01 + i) * 0.3;
      p.y   += p.vy;
      p.rot += p.vRot;
      drawPetal(p);

      // 离开底部后重置到顶部
      if (p.y > H + 30) petals[i] = createPetal(false);
    }

    frameCount++;
    frameId = requestAnimationFrame(tick);
  }

  // ── 生命周期 ──────────────────────────────────────────────────────
  resize();
  initParticles();
  tick();

  window.addEventListener('resize', () => {
    cancelAnimationFrame(frameId);
    resize();
    initParticles();
    tick();
  }, { passive: true });
</script>
