---
/**
 * @component StarField
 * @description 固定背景 Canvas —— 极简几何轮廓粒子（圆环 / 方框 / 短线 / 微点）。
 *              颜色从 CSS 变量 --particle-color / --particle-accent 取，
 *              所以切换日/夜主题时粒子会自然跟着换色。
 *              pointer-events-none，不干扰任何交互。
 *
 * 数量/节奏经过 HANDOFF 调校：
 *   - count ≤ 22，不堆屏（再多显得廉价）
 *   - vy 0.05–0.17 × dpr，非常慢，像气泡在上升
 *   - alpha 上限 0.22，几乎只是轮廓
 */
---

<canvas id="starfield" class="fixed inset-0 pointer-events-none z-0" aria-hidden="true"></canvas>

<script>
  // ── 类型定义 ──────────────────────────────────────────────────────
  type ParticleType = 'ring' | 'square' | 'line' | 'dot';

  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;
    life: number; // 用作渐入：alpha 随 life 饱和到 1
    type: ParticleType;
    rot: number;
    vr: number;
    depth: number; // 0.4–1.0，用作景深 alpha/速度调制
  }

  // ── Canvas 初始化 ─────────────────────────────────────────────────
  const canvas = document.getElementById('starfield') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let W = 0,
    H = 0;
  let particles: Particle[] = [];
  let frameId = 0;
  const dpr = Math.min(2, window.devicePixelRatio || 1); // 手机高 DPR 时压到 2，控制 GPU 负担

  function resize() {
    W = canvas.width = window.innerWidth * dpr;
    H = canvas.height = window.innerHeight * dpr;
    canvas.style.width = window.innerWidth + 'px';
    canvas.style.height = window.innerHeight + 'px';
  }

  // ── 粒子工厂 ─────────────────────────────────────────────────────
  const SHAPES: ParticleType[] = ['ring', 'square', 'line', 'dot'];

  function makeParticle(seedY = false): Particle {
    const type = SHAPES[Math.floor(Math.random() * SHAPES.length)]!;
    return {
      x: Math.random() * W,
      y: seedY ? Math.random() * H : -40,
      vx: (Math.random() - 0.5) * 0.08 * dpr,
      vy: (0.05 + Math.random() * 0.12) * dpr,
      size: (18 + Math.random() * 42) * dpr,
      life: seedY ? Math.random() : 0,
      type,
      rot: Math.random() * Math.PI * 2,
      vr: (Math.random() - 0.5) * 0.0015,
      depth: 0.4 + Math.random() * 0.6,
    };
  }

  function initParticles() {
    // HANDOFF 规定：Math.min(22, (w*h)/70000)
    const count = Math.min(22, Math.floor((window.innerWidth * window.innerHeight) / 70000));
    particles = Array.from({ length: count }, () => makeParticle(true));
  }

  // ── 读取 CSS 变量 ─────────────────────────────────────────────────
  // :root 里存的是 "236 72 153"（空格分隔），rgba() 需要逗号，这里转一下。
  // 缓存在模块闭包里：每帧 tick() 读这个变量，不再调 getComputedStyle
  // （getComputedStyle 会同步触发 layout 回算，每帧 60Hz × 2 次 = 持续热点）。
  // 主题切换时由 NavBar 派发的 'theme:change' 事件触发一次重取。
  function getColors() {
    const cs = getComputedStyle(document.documentElement);
    const norm = (v: string) => v.trim().split(/\s+/).join(',');
    return {
      main: norm(cs.getPropertyValue('--particle-color')) || '236,72,153',
      accent: norm(cs.getPropertyValue('--particle-accent')) || '217,147,33',
    };
  }
  let colors = getColors();

  // ── 绘制 + 主循环 ──────────────────────────────────────────────────
  function tick() {
    if (!running) return;
    ctx.clearRect(0, 0, W, H);
    const { main, accent } = colors;

    for (const p of particles) {
      p.x += p.vx;
      p.y += p.vy;
      p.rot += p.vr;
      p.life = Math.min(1, p.life + 0.002);

      // 回收：飘出视口任何一侧 → 重置到顶部
      if (p.y - p.size > H + 40 || p.x < -p.size - 40 || p.x > W + p.size + 40) {
        Object.assign(p, makeParticle(false));
      }

      const alpha = p.life * 0.22 * p.depth;
      const rgb = p.type === 'line' || p.type === 'square' ? accent : main;

      ctx.save();
      ctx.translate(p.x, p.y);
      ctx.rotate(p.rot);
      ctx.strokeStyle = `rgba(${rgb}, ${alpha})`;
      ctx.lineWidth = Math.max(1, 0.9 * dpr);

      if (p.type === 'ring') {
        ctx.beginPath();
        ctx.arc(0, 0, p.size * 0.5, 0, Math.PI * 2);
        ctx.stroke();
      } else if (p.type === 'square') {
        const s = p.size * 0.45;
        ctx.strokeRect(-s, -s, s * 2, s * 2);
      } else if (p.type === 'line') {
        ctx.beginPath();
        ctx.moveTo(-p.size * 0.6, 0);
        ctx.lineTo(p.size * 0.6, 0);
        ctx.stroke();
      } else {
        // dot：微小实心，亮度略高让点更有存在感
        ctx.fillStyle = `rgba(${rgb}, ${alpha * 1.4})`;
        ctx.beginPath();
        ctx.arc(0, 0, Math.max(1.2, 1.4 * dpr), 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.restore();
    }

    frameId = requestAnimationFrame(tick);
  }

  // ── 动画开关 ──────────────────────────────────────────────────────
  //   JS 动画（requestAnimationFrame）不受 CSS `animation: none` 约束，必须在 JS
  //   里自己检查 prefers-reduced-motion，否则「减弱动态效果」用户依旧被强制观看。
  const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
  let running = false;

  function start() {
    if (running) return;
    if (motionQuery.matches || document.hidden) return;
    running = true;
    tick();
  }
  function stop() {
    if (!running) return;
    running = false;
    cancelAnimationFrame(frameId);
    ctx.clearRect(0, 0, W, H);
  }

  // ── 生命周期 ──────────────────────────────────────────────────────
  resize();
  initParticles();
  start();

  motionQuery.addEventListener('change', () => {
    motionQuery.matches ? stop() : start();
  });

  document.addEventListener('visibilitychange', () => {
    document.hidden ? stop() : start();
  });

  // 主题切换：重取 CSS 变量色值，下一帧 tick() 就用新色。
  document.addEventListener('theme:change', () => {
    colors = getColors();
  });

  // 只在尺寸变化时重建粒子，保持密度正确。
  window.addEventListener(
    'resize',
    () => {
      stop();
      resize();
      initParticles();
      start();
    },
    { passive: true },
  );
</script>
