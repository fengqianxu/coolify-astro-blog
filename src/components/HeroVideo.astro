---
/**
 * @component HeroVideo
 * @description 首页全屏视频开屏区。
 *
 * 结构：
 *  - 背景视频（autoplay / muted / loop），随主题切换资源
 *  - 底部渐变遮罩（视频 → 页面背景色，过渡自然）
 *  - 中央叠加文字（站名 + 副标题）
 *  - 底部滚动引导箭头（可点击跳过）
 */

import { SITE } from '../config/site';
---

<section
  id="hero-splash"
  class="relative w-full h-dvh overflow-hidden flex items-center justify-center"
  aria-label="开场动态视频"
>
  <!--
    背景视频：
      data-src-dark / data-src-light 由脚本根据主题选用
      初始 src 由内联脚本依据 localStorage 在 SSR HTML 上就地设置（避免切换闪烁）
  -->
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover"
    data-src-dark={SITE.heroVideo}
    data-src-light={SITE.heroVideoLight}
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    aria-hidden="true"
  ></video>

  <!-- 渐变遮罩：顶部微暗（提升导航可读性）→ 底部收入页面背景色（用 void-900） -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.35) 0%,
      transparent      30%,
      transparent      60%,
      rgb(var(--c-void-900)) 100%
    );"
    aria-hidden="true"
  ></div>

  <!-- 中央文字叠加 -->
  <div class="relative z-10 text-center px-6 animate-fade-in">
    <p class="text-white/60 text-xs tracking-[0.25em] uppercase mb-4 font-body">
      Welcome to
    </p>
    <h1 class="font-heading text-6xl sm:text-8xl font-bold text-white
               drop-shadow-[0_2px_20px_rgba(255,45,107,0.5)] mb-4 leading-none">
      {SITE.name}
    </h1>
    <p class="text-white/70 text-base sm:text-lg font-body tracking-wide">
      {SITE.description}
    </p>
  </div>

  <!-- 滚动引导 -->
  <button
    id="scroll-hint"
    type="button"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10
           flex flex-col items-center gap-1.5 cursor-pointer
           text-white/50 hover:text-white/90
           transition-colors duration-300 group"
    aria-label="向下滚动查看内容"
    onclick="window.scrollTo({ top: window.innerHeight, behavior: 'smooth' })"
  >
    <span class="text-[10px] tracking-[0.3em] uppercase font-body">Scroll</span>
    {[0, 120, 240].map((delay) => (
      <svg
        class="w-4 h-4 animate-bounce"
        style={`animation-delay: ${delay}ms; opacity: ${0.4 + delay / 600}`}
        fill="none" stroke="currentColor" stroke-width="2.5"
        viewBox="0 0 24 24" aria-hidden="true"
      >
        <path d="m6 9 6 6 6-6"/>
      </svg>
    ))}
  </button>
</section>

<script>
  // ── 根据当前主题装载正确的视频源 ────────────────────────────────
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  if (video) {
    const srcDark  = video.dataset.srcDark!;
    const srcLight = video.dataset.srcLight!;

    function applyVideo(dark: boolean) {
      const target = dark ? srcDark : srcLight;
      // 避免重复设置相同资源，防止 Safari 重新缓冲中断播放
      if (video!.getAttribute('src') === target) return;
      video!.src = target;
      video!.load();
      video!.play().catch(() => { /* 自动播放可能被浏览器阻止，静默忽略 */ });
    }

    // 初始装载：当前 <html> 的 .dark 状态由 Layout 的 inline 脚本在渲染前决定
    applyVideo(document.documentElement.classList.contains('dark'));

    // 响应主题切换事件
    document.addEventListener('theme:change', ((e: CustomEvent) => {
      applyVideo(Boolean(e.detail?.dark));
    }) as EventListener);
  }
</script>
