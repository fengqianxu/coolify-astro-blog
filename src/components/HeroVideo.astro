---
/**
 * @component HeroVideo
 * @description 首页全屏视频开屏区。
 *
 * 结构：
 *  - 背景视频（autoplay / muted / loop）
 *  - 底部渐变遮罩（视频→页面背景色，过渡自然）
 *  - 中央叠加文字（站名 + 副标题）
 *  - 底部滚动引导箭头（可点击跳过）
 */

import { SITE } from '../config/site';
---

<section
  id="hero-splash"
  class="relative w-full h-dvh overflow-hidden flex items-center justify-center"
  aria-label="开场动态视频"
>
  <!-- 背景视频 -->
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover"
    src={SITE.heroVideo}
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    aria-hidden="true"
  ></video>

  <!-- 渐变遮罩：顶部微暗（提升导航可读性）→ 底部完全收入页面背景色 -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(
      to bottom,
      rgba(13,11,20,0.35) 0%,
      transparent        30%,
      transparent        60%,
      #13111c           100%
    );"
    aria-hidden="true"
  ></div>

  <!-- 中央文字叠加 -->
  <div class="relative z-10 text-center px-6 animate-fade-in">
    <p class="text-white/60 text-xs tracking-[0.25em] uppercase mb-4 font-body">
      Welcome to
    </p>
    <h1 class="font-heading text-6xl sm:text-8xl font-bold text-white
               drop-shadow-[0_2px_20px_rgba(244,114,182,0.5)] mb-4 leading-none">
      {SITE.name}
    </h1>
    <p class="text-white/70 text-base sm:text-lg font-body tracking-wide">
      {SITE.description}
    </p>
  </div>

  <!-- 滚动引导 -->
  <button
    id="scroll-hint"
    type="button"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10
           flex flex-col items-center gap-1.5 cursor-pointer
           text-white/50 hover:text-white/90
           transition-colors duration-300 group"
    aria-label="向下滚动查看内容"
    onclick="window.scrollTo({ top: window.innerHeight, behavior: 'smooth' })"
  >
    <span class="text-[10px] tracking-[0.3em] uppercase font-body">Scroll</span>
    <!-- 三层渐强的跳动箭头 -->
    {[0, 120, 240].map((delay) => (
      <svg
        class="w-4 h-4 animate-bounce"
        style={`animation-delay: ${delay}ms; opacity: ${0.4 + delay / 600}`}
        fill="none" stroke="currentColor" stroke-width="2.5"
        viewBox="0 0 24 24" aria-hidden="true"
      >
        <path d="m6 9 6 6 6-6"/>
      </svg>
    ))}
  </button>
</section>
