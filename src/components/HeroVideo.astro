---
/**
 * @component HeroVideo
 * @description 首页全屏视频开屏区。
 *
 * 结构：
 *  - 背景视频（autoplay / muted / loop），随主题切换资源
 *  - 底部渐变遮罩（视频 → 页面背景色，过渡自然）
 *  - 中央叠加文字（站名 + 副标题）
 *  - 底部滚动引导箭头（可点击跳过）
 */

import { SITE } from '../config/site';
---

<section
  id="hero-splash"
  class="relative w-full h-dvh overflow-hidden flex items-center justify-center"
  aria-label="开场动态视频"
>
  <!--
    背景视频：
      data-src-dark / data-src-light 由脚本根据主题选用
      初始 src 由内联脚本依据 localStorage 在 SSR HTML 上就地设置（避免切换闪烁）
  -->
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover"
    data-src-dark={SITE.heroVideo}
    data-src-light={SITE.heroVideoLight}
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    aria-hidden="true"
  ></video>

  <!-- 渐变遮罩：顶部微暗（提升导航可读性）→ 中部略暗（兜住中央文字）→ 底部收入页面背景色 -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.45) 0%,
      rgba(0,0,0,0.25) 30%,
      rgba(0,0,0,0.30) 55%,
      rgb(var(--c-void-900)) 100%
    );"
    aria-hidden="true"
  ></div>

  <!-- 中央文字叠加 -->
  <div class="hero-center relative z-10 text-center px-6 animate-fade-in">
    <p class="hero-kicker text-xs tracking-[0.25em] uppercase mb-4 font-body">
      Welcome to
    </p>
    <h1 class="hero-title font-heading text-6xl sm:text-8xl font-bold mb-4 leading-none">
      {SITE.name}
    </h1>
    <p class="hero-sub text-base sm:text-lg font-body tracking-wide">
      {SITE.description}
    </p>
  </div>

  <!-- 滚动引导 -->
  <button
    id="scroll-hint"
    type="button"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10
           flex flex-col items-center gap-1.5 cursor-pointer
           text-white/50 hover:text-white/90
           transition-colors duration-300 group"
    aria-label="向下滚动查看内容"
    onclick="window.scrollTo({ top: window.innerHeight, behavior: 'smooth' })"
  >
    <span class="text-[10px] tracking-[0.3em] uppercase font-body">Scroll</span>
    {[0, 120, 240].map((delay) => (
      <svg
        class="w-4 h-4 animate-bounce"
        style={`animation-delay: ${delay}ms; opacity: ${0.4 + delay / 600}`}
        fill="none" stroke="currentColor" stroke-width="2.5"
        viewBox="0 0 24 24" aria-hidden="true"
      >
        <path d="m6 9 6 6 6-6"/>
      </svg>
    ))}
  </button>
</section>

<script>
  // ── 根据当前主题装载正确的视频源 ────────────────────────────────
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  if (video) {
    const srcDark  = video.dataset.srcDark!;
    const srcLight = video.dataset.srcLight!;

    function applyVideo(dark: boolean) {
      const target = dark ? srcDark : srcLight;
      // 避免重复设置相同资源，防止 Safari 重新缓冲中断播放
      if (video!.getAttribute('src') === target) return;
      video!.src = target;
      video!.load();
      video!.play().catch(() => { /* 自动播放可能被浏览器阻止，静默忽略 */ });
    }

    // 初始装载：当前 <html> 的 .dark 状态由 Layout 的 inline 脚本在渲染前决定
    applyVideo(document.documentElement.classList.contains('dark'));

    // 响应主题切换事件
    document.addEventListener('theme:change', ((e: CustomEvent) => {
      applyVideo(Boolean(e.detail?.dark));
    }) as EventListener);
  }
</script>

<style>
  /*
   * Hero 中央文字：在暗色/亮色视频上都要清晰可读。
   * 策略：统一白字，用多层 text-shadow 模拟深色描边兜底。
   */
  .hero-kicker {
    color: rgba(255, 255, 255, 0.88);
    text-shadow:
      0 1px 4px rgba(0, 0, 0, 0.6),
      0 0 16px rgba(0, 0, 0, 0.45);
  }
  .hero-title {
    color: #fff;
    text-shadow:
      0 2px 6px rgba(0, 0, 0, 0.7),
      0 0 24px rgba(0, 0, 0, 0.45),
      0 2px 20px rgba(255, 45, 107, 0.35);
  }
  .hero-sub {
    color: rgba(255, 255, 255, 0.95);
    text-shadow:
      0 1px 4px rgba(0, 0, 0, 0.7),
      0 0 14px rgba(0, 0, 0, 0.45);
  }

  /* 亮色模式下视频更亮，阴影再加深一档，并把副标加粗一点 */
  :root:not(.dark) .hero-kicker {
    color: #fff;
    text-shadow:
      0 1px 4px rgba(0, 0, 0, 0.85),
      0 0 18px rgba(0, 0, 0, 0.6);
  }
  :root:not(.dark) .hero-title {
    text-shadow:
      0 2px 6px rgba(0, 0, 0, 0.85),
      0 0 28px rgba(0, 0, 0, 0.55),
      0 2px 20px rgba(255, 45, 107, 0.3);
  }
  :root:not(.dark) .hero-sub {
    color: #fff;
    font-weight: 500;
    text-shadow:
      0 1px 4px rgba(0, 0, 0, 0.9),
      0 0 16px rgba(0, 0, 0, 0.6);
  }
</style>
