---
// Full-viewport video splash shown on first load.
// The actual content lives below it and is revealed on scroll.
---

<section
  id="hero-splash"
  class="relative w-full h-dvh overflow-hidden flex items-center justify-center"
  aria-label="开场动态视频"
>
  <!-- ── Background video ─────────────────────────── -->
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover"
    src="/videos/bg.mp4"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
  ></video>

  <!-- ── Soft gradient overlay (bottom fade → content) -->
  <div class="absolute inset-0 bg-gradient-to-b
              from-black/20 via-transparent to-surface-100/90
              pointer-events-none"></div>

  <!-- ── Centre overlay: site name + tagline ───────── -->
  <div class="relative z-10 text-center px-6 animate-fade-in drop-shadow-xl">
    <p class="text-white/80 text-sm tracking-widest uppercase mb-3 font-body">Welcome to</p>
    <h1 class="font-heading text-6xl sm:text-8xl font-bold text-white drop-shadow-lg mb-4">
      AniLog
    </h1>
    <p class="text-white/70 text-lg sm:text-xl font-body">
      记录技术成长，分享二次元热情
    </p>
  </div>

  <!-- ── Scroll-down indicator ─────────────────────── -->
  <div
    id="scroll-hint"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10
           flex flex-col items-center gap-2 cursor-pointer
           text-white/60 hover:text-white/90 transition-colors duration-300"
    aria-label="向下滚动"
    role="button"
    tabindex="0"
  >
    <span class="text-xs tracking-widest font-body">SCROLL</span>
    <!-- Animated chevron trio -->
    <div class="flex flex-col items-center gap-0.5">
      <svg class="w-5 h-5 opacity-40 animate-bounce [animation-delay:0ms]"
           fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path d="m6 9 6 6 6-6"/>
      </svg>
      <svg class="w-5 h-5 opacity-65 animate-bounce [animation-delay:120ms]"
           fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path d="m6 9 6 6 6-6"/>
      </svg>
      <svg class="w-5 h-5 opacity-90 animate-bounce [animation-delay:240ms]"
           fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </div>
  </div>
</section>

<script>
  // Clicking the scroll hint scrolls past the splash
  const hint = document.getElementById('scroll-hint');
  hint?.addEventListener('click', () => {
    window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
  });
  hint?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
    }
  });
</script>
