---
/**
 * @component NavBar
 * @description 固定顶部导航栏。
 *
 * 行为：
 *  - heroVideo=true 时，初始透明覆盖在视频上（渐变遮罩保证文字可读）。
 *  - 滚过视口 80% 后切换为深色磨砂玻璃（nav-solid）。
 *  - heroVideo=false 时，始终使用 nav-solid 样式。
 *
 * 搜索：派发 "search:open" 自定义事件，由 SearchModal 统一处理。
 *
 * 图标：线性 SVG（Lucide 风格），stroke-width=1.75，w-4 h-4，
 *       走 currentColor 从文字颜色继承，保证与主题色一致。
 */

import { SITE } from '../config/site';

interface Props {
  heroVideo?: boolean;
}
const { heroVideo = false } = Astro.props;

const current = Astro.url.pathname;
const isHome  = current === '/';
const isBlog  = current.startsWith('/blog')
             || current.startsWith('/tags')
             || current.startsWith('/categories')
             || current.startsWith('/archives');
const isAbout = current.startsWith('/about');
---

<header
  id="site-header"
  data-hero={heroVideo}
  class="fixed top-0 inset-x-0 z-40 transition-transform duration-300 ease-out will-change-transform"
>
  <!-- ── 主导航栏 ───────────────────────────────────────── -->
  <div
    id="nav-bar"
    class:list={[
      'w-full flex items-center justify-between gap-4',
      'px-5 sm:px-8 h-14',
      'transition-all duration-300',
      heroVideo ? 'nav-over-video' : 'nav-solid',
    ]}
  >

    <!--
      Logo ───────────────────────────────────────────────
      用户自己会在 /public 里放 logo.svg 或 logo.png，放进来前先用
      渐变方块兜底；img 加载失败时 onerror 把自己隐藏，用户不会看到破图。
      logo-mark 已在 global.css 定义好（40×40 圆角，brand-grad 背景，
      hover 微旋）。这里刻意不写站名文字，让 logo 图形承担全部品牌呈现。
    -->
    <a href="/" class="logo-mark" aria-label={SITE.name}>
      <img
        src="/logo.svg"
        alt={SITE.name}
        width="40"
        height="40"
        onerror="this.style.display='none'"
      />
    </a>

    <!-- Desktop links ──────────────────────────────────── -->
    <nav class="hidden md:flex items-center gap-0.5" role="menubar" aria-label="主导航">

      <a
        href="/"
        role="menuitem"
        aria-current={isHome ? 'page' : undefined}
        class:list={['nav-link', isHome && 'nav-link-active']}
      >
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/>
          <path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        </svg>
        <span>首页</span>
      </a>

      <!-- 文章（含下拉） -->
      <div class="relative group/article" role="none">
        <a
          href="/blog"
          role="menuitem"
          aria-haspopup="menu"
          aria-current={isBlog ? 'page' : undefined}
          class:list={['nav-link', isBlog && 'nav-link-active']}
        >
          <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12.67 19a2 2 0 0 0 1.416-.588l6.154-6.172a6 6 0 0 0-8.49-8.49L5.586 9.914A2 2 0 0 0 5 11.328V18a1 1 0 0 0 1 1z"/>
            <path d="M16 8 2 22"/>
            <path d="M17.5 15H9"/>
          </svg>
          <span>文章</span>
          <svg
            class="w-3 h-3 opacity-50 transition-transform duration-200 group-hover/article:rotate-180"
            fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
          ><path d="m6 9 6 6 6-6"/></svg>
        </a>

        <!--
          Dropdown：
           - 使用 pt-2 作为"不可见桥接区"填补按钮与下拉之间的空隙，鼠标移入不会丢失 hover
           - 关闭延时 180ms 给用户容错
        -->
        <div
          class="absolute left-0 top-full w-36 pt-2
                 opacity-0 invisible translate-y-1
                 group-hover/article:opacity-100 group-hover/article:visible group-hover/article:translate-y-0
                 transition-[opacity,transform,visibility] duration-200 ease-out
                 delay-[180ms] group-hover/article:delay-0"
          role="menu"
        >
          <div class="glass-card py-1 text-sm overflow-hidden">
            <a href="/categories" class="dropdown-item" role="menuitem">
              <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/>
              </svg>
              <span>分类</span>
            </a>
            <a href="/tags" class="dropdown-item" role="menuitem">
              <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/>
                <circle cx="7.5" cy="7.5" r="1" fill="currentColor" stroke="none"/>
              </svg>
              <span>标签</span>
            </a>
            <a href="/archives" class="dropdown-item" role="menuitem">
              <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="20" height="5" x="2" y="3" rx="1"/>
                <path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/>
                <path d="M10 12h4"/>
              </svg>
              <span>归档</span>
            </a>
          </div>
        </div>
      </div>

      <a
        href="/about"
        role="menuitem"
        aria-current={isAbout ? 'page' : undefined}
        class:list={['nav-link', isAbout && 'nav-link-active']}
      >
        <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
        <span>关于</span>
      </a>

    </nav>

    <!-- Controls ───────────────────────────────────────── -->
    <div class="flex items-center gap-1 shrink-0">
      <button
        id="search-open-btn"
        type="button"
        aria-label="搜索文章（Ctrl+K）"
        class="nav-icon-btn"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5"
             viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </button>

      <!-- 日/夜模式切换 -->
      <button
        id="theme-toggle-btn"
        type="button"
        aria-label="切换日间 / 夜间模式"
        class="nav-icon-btn"
      >
        <!-- 夜间时显示月亮（点击切到日间）-->
        <svg id="theme-icon-moon" class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" stroke-width="2.5"
             viewBox="0 0 24 24" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"/>
        </svg>
        <!-- 日间时显示太阳（点击切到夜间）-->
        <svg id="theme-icon-sun" class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" stroke-width="2.5"
             viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
      </button>

      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="打开菜单"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden nav-icon-btn"
      >
        <svg id="menu-icon-open"  class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- ── 移动端菜单 ────────────────────────────────────── -->
  <div
    id="mobile-menu"
    role="menu"
    hidden
    class="nav-solid border-t border-white/6 px-4 py-2"
  >
    <a href="/" role="menuitem" class="mobile-nav-item" aria-current={isHome ? 'page' : undefined}>
      <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/>
        <path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
      </svg>
      <span>首页</span>
    </a>
    <a href="/blog" role="menuitem" class="mobile-nav-item" aria-current={isBlog ? 'page' : undefined}>
      <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12.67 19a2 2 0 0 0 1.416-.588l6.154-6.172a6 6 0 0 0-8.49-8.49L5.586 9.914A2 2 0 0 0 5 11.328V18a1 1 0 0 0 1 1z"/>
        <path d="M16 8 2 22"/>
        <path d="M17.5 15H9"/>
      </svg>
      <span>文章</span>
    </a>
    <div class="pl-4 border-l-2 border-sakura-700/40 ml-3 my-0.5 space-y-0.5">
      <a href="/categories" role="menuitem" class="mobile-nav-item text-xs">
        <svg class="nav-ico-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/>
        </svg>
        <span>分类</span>
      </a>
      <a href="/tags" role="menuitem" class="mobile-nav-item text-xs">
        <svg class="nav-ico-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/>
          <circle cx="7.5" cy="7.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        <span>标签</span>
      </a>
      <a href="/archives" role="menuitem" class="mobile-nav-item text-xs">
        <svg class="nav-ico-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="5" x="2" y="3" rx="1"/>
          <path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/>
          <path d="M10 12h4"/>
        </svg>
        <span>归档</span>
      </a>
    </div>
    <a href="/about" role="menuitem" class="mobile-nav-item" aria-current={isAbout ? 'page' : undefined}>
      <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      <span>关于</span>
    </a>
  </div>
</header>

<script>
  // ── 滚动感知：借鉴 Shoka 主题 ──────────────────────────
  //   1. 过阈值后切换 nav-solid（磨砂底）
  //   2. 过阈值后，向下滚：隐藏（translateY(-100%)）；向上滚：显示
  const header = document.getElementById('site-header')!;
  const navBar = document.getElementById('nav-bar')!;
  const isHero = header.dataset.hero === 'true';

  // 视频首屏：越过 80% 视口；普通页面：越过 nav 高度
  //   用 let：窗口尺寸变化时（横竖屏切换 / 缩放）需要重算，否则横屏滚动阈值会错。
  let scrollThreshold = isHero ? window.innerHeight * 0.8 : 64;

  let lastY   = window.scrollY;
  let ticking = false;

  function computeScroll() {
    const currentY = window.scrollY;
    const passed = currentY > scrollThreshold;

    // 背景样式切换（只对 hero 页生效，普通页永远是 solid）
    if (isHero) {
      if (passed) {
        navBar.classList.replace('nav-over-video', 'nav-solid');
      } else {
        navBar.classList.replace('nav-solid', 'nav-over-video');
      }
    }

    // 方向感知隐藏/显示
    if (passed) {
      const scrollingDown = currentY > lastY;
      // 轻微抖动不切换（阈值 4px）
      if (Math.abs(currentY - lastY) > 4) {
        header.style.transform = scrollingDown ? 'translateY(-100%)' : 'translateY(0)';
      }
    } else {
      header.style.transform = 'translateY(0)';
    }

    lastY = currentY;
    ticking = false;
  }

  // rAF 节流：滚动事件可能 120Hz 触发，合并到下一帧处理避免浪费 CPU。
  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(computeScroll);
  }

  // 初始态
  computeScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // 窗口尺寸变化时重算阈值（手机横竖屏 / 桌面窗口缩放）
  window.addEventListener('resize', () => {
    scrollThreshold = isHero ? window.innerHeight * 0.8 : 64;
  }, { passive: true });

  // ── 移动端菜单开关 ────────────────────────────────────────────────
  const menuBtn    = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconOpen   = document.getElementById('menu-icon-open')!;
  const iconClose  = document.getElementById('menu-icon-close')!;

  menuBtn.addEventListener('click', () => {
    const opening = mobileMenu.hidden;
    mobileMenu.hidden = !opening;
    menuBtn.setAttribute('aria-expanded', String(opening));
    menuBtn.setAttribute('aria-label', opening ? '关闭菜单' : '打开菜单');
    iconOpen.classList.toggle('hidden', opening);
    iconClose.classList.toggle('hidden', !opening);
  });

  // ── 搜索：派发自定义事件，SearchModal 负责处理打开逻辑 ───────────
  const searchBtn = document.getElementById('search-open-btn')!;

  function dispatchOpenSearch() {
    document.dispatchEvent(new CustomEvent('search:open'));
  }

  searchBtn.addEventListener('click', dispatchOpenSearch);

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      dispatchOpenSearch();
    }
  });

  // ── 主题切换：View Transitions API（径向扩散过渡） ────
  //   支持的浏览器（Chrome 111+ / Edge / Safari 18+）会用浏览器原生的
  //   cross-fade + position-based animation；不支持的走同步切换，
  //   视觉上就是瞬切，但不会出错。
  const themeBtn = document.getElementById('theme-toggle-btn')!;

  function applyTheme(nowDark: boolean) {
    document.documentElement.classList.toggle('dark', nowDark);
    localStorage.setItem('theme', nowDark ? 'dark' : 'light');
    // 通知其他组件（HeroVideo）切换视频资源
    document.dispatchEvent(new CustomEvent('theme:change', { detail: { dark: nowDark } }));
  }

  themeBtn.addEventListener('click', () => {
    const nowDark = !document.documentElement.classList.contains('dark');
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // @ts-ignore - View Transitions API（Chromium 111+/Safari 18+）尚未进标准 DOM lib
    const vt = !prefersReduced && document.startViewTransition?.bind(document);
    if (vt) {
      vt(() => applyTheme(nowDark));
    } else {
      applyTheme(nowDark);
    }
  });
</script>
