---
/**
 * @component NavBar
 * @description 固定顶部导航栏。
 *
 * 行为：
 *  - heroVideo=true 时，初始为半透明暗底（nav-over-video）覆盖在视频上，
 *    文字始终白色且清晰可见。
 *  - 滚过视口 80% 后切换为深色磨砂玻璃（nav-solid）。
 *  - heroVideo=false 时，始终使用 nav-solid 样式，顶部留 --nav-height 间距。
 *
 * 搜索：点击 🔍 按钮或按 Ctrl/Cmd + K 打开搜索弹窗（#search-modal）。
 */

import { SITE, NAV_LINKS } from '../config/site';

interface Props {
  /** 是否处于全屏视频首屏模式 */
  heroVideo?: boolean;
}
const { heroVideo = false } = Astro.props;

const current = Astro.url.pathname;
---

<header
  id="site-header"
  data-hero={heroVideo}
  class="fixed top-0 inset-x-0 z-40"
  style="transition: none;"
>
  <div class="flex justify-center px-4 pt-3">
    <nav
      id="nav-pill"
      class:list={[
        'w-full max-w-4xl rounded-2xl px-6 py-3',
        'flex items-center justify-between gap-4',
        'transition-[background,border-color,box-shadow] duration-400',
        heroVideo ? 'nav-over-video' : 'nav-solid',
      ]}
    >
      <!-- ── Logo ──────────────────────────────────── -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <span class="text-xl select-none animate-bounce-gentle inline-block" aria-hidden="true">🌸</span>
        <span id="nav-logo" class="font-heading font-semibold text-lg transition-all duration-400 text-gradient">
          {SITE.name}
        </span>
      </a>

      <!-- ── Desktop links ─────────────────────────── -->
      <ul class="hidden sm:flex items-center gap-1" role="menubar">
        {NAV_LINKS.map(({ href, label }) => {
          const isActive = href === '/'
            ? current === href
            : current.startsWith(href);
          return (
            <li role="none">
              <a
                href={href}
                role="menuitem"
                aria-current={isActive ? 'page' : undefined}
                class:list={[
                  'nav-link px-4 py-1.5 rounded-xl text-sm font-medium',
                  'transition-all duration-200',
                  isActive
                    ? 'bg-sakura-500/20 text-sakura-300 border border-sakura-500/40'
                    : 'text-lavender-300 hover:text-white hover:bg-white/8',
                ]}
              >
                {label}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- ── Controls ──────────────────────────────── -->
      <div class="flex items-center gap-1 shrink-0">
        <!-- 搜索按钮 -->
        <button
          id="search-open-btn"
          type="button"
          aria-label="搜索文章（Ctrl+K）"
          class="p-2 rounded-xl text-lavender-400 hover:text-sakura-400
                 hover:bg-sakura-500/10 transition-all duration-200 cursor-pointer"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"
               viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </button>

        <!-- 移动端菜单按钮 -->
        <button
          id="mobile-menu-btn"
          type="button"
          aria-label="打开菜单"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="sm:hidden p-2 rounded-xl text-lavender-400 hover:text-white
                 hover:bg-white/8 transition-all duration-200 cursor-pointer"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"
               viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- ── 移动端下拉菜单 ─────────────────────────────── -->
  <div
    id="mobile-menu"
    role="menu"
    hidden
    class="mx-4 mt-1 nav-solid rounded-2xl px-4 py-3"
  >
    {NAV_LINKS.map(({ href, label }) => (
      <a
        href={href}
        role="menuitem"
        class="block px-3 py-2.5 rounded-xl text-sm text-lavender-300
               hover:text-white hover:bg-white/8 transition-all duration-200"
      >
        {label}
      </a>
    ))}
  </div>
</header>

<script>
  // ── 滚动感知：在视频首屏与正文之间切换导航栏样式 ─────────────────
  const header  = document.getElementById('site-header')!;
  const navPill = document.getElementById('nav-pill')!;
  const isHero  = header.dataset.hero === 'true';

  if (isHero) {
    const SCROLL_THRESHOLD = window.innerHeight * 0.8;

    function applyNavState(scrolled: boolean) {
      if (scrolled) {
        navPill.classList.replace('nav-over-video', 'nav-solid');
      } else {
        navPill.classList.replace('nav-solid', 'nav-over-video');
      }
    }

    // 立即执行一次，避免初始闪烁
    applyNavState(window.scrollY > SCROLL_THRESHOLD);
    // 滚动时更新（passive 保证不阻塞渲染）
    window.addEventListener('scroll', () => {
      applyNavState(window.scrollY > SCROLL_THRESHOLD);
    }, { passive: true });
  }

  // ── 移动端菜单开关 ────────────────────────────────────────────────
  const menuBtn  = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  menuBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.hidden;
    mobileMenu.hidden = isOpen;
    menuBtn.setAttribute('aria-expanded', String(!isOpen));
    menuBtn.setAttribute('aria-label', isOpen ? '打开菜单' : '关闭菜单');
  });

  // ── 搜索快捷键 & 按钮 ────────────────────────────────────────────
  const searchBtn   = document.getElementById('search-open-btn')!;
  const searchModal = document.getElementById('search-modal');

  function openSearch() {
    if (!searchModal) return;
    searchModal.removeAttribute('hidden');
    searchModal.querySelector<HTMLInputElement>('#search-input')?.focus();
  }

  searchBtn.addEventListener('click', openSearch);

  document.addEventListener('keydown', (e) => {
    // Ctrl+K 或 Cmd+K 打开搜索
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
  });
</script>
