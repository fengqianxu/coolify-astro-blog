---
/**
 * @component PostCard
 * @description 文章预览卡片，用于首页网格和博客列表页。
 *
 * @prop slug       文章唯一路径段
 * @prop title      文章标题
 * @prop description 摘要
 * @prop pubDate    发布日期
 * @prop tags       标签数组（最多展示 3 个）
 * @prop category   分类名称
 * @prop heroImage  封面图路径（可选，缺省时显示分类渐变占位）
 * @prop featured   是否置顶/精选（占双列宽）
 */

import type { PostSummary } from '../types';
import { CATEGORY_EMOJI, CATEGORY_GRADIENT, LIMITS } from '../config/site';
import { fmtLong } from '../utils/date';

/**
 * PostCard 接受的 category 是 string[]（层级路径）。
 * - 卡片徽章只显示叶子分类（最具体那一层）
 * - 封面占位符的 emoji/渐变按「叶子」优先、否则按「根」取，最后回落到默认
 */
type Props = PostSummary;

const { slug, title, description, pubDate, tags, category, heroImage, featured } = Astro.props;

const dateStr = fmtLong(pubDate);

const leaf = category[category.length - 1] ?? '随笔';
const root = category[0] ?? '随笔';

const emoji    = CATEGORY_EMOJI[leaf]    ?? CATEGORY_EMOJI[root]    ?? '✨';
const gradient = CATEGORY_GRADIENT[leaf] ?? CATEGORY_GRADIENT[root] ?? 'from-void-800/80 to-void-700/60';
---

<article
  class:list={[
    'glass-card overflow-hidden group relative',
    'transition-transform duration-300 hover:-translate-y-1',
    featured ? 'sm:col-span-2' : '',
  ]}
>
  <!-- ── 封面区域 ─────────────────────────────────────── -->
  <div class:list={['relative aspect-video overflow-hidden bg-gradient-to-br', gradient]}>
    {heroImage
      ? (
        <img
          src={heroImage}
          alt={`${title} 封面图`}
          loading="lazy"
          decoding="async"
          width="1600"
          height="900"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      )
      : (
        <div class="absolute inset-0 flex items-center justify-center">
          <span
            class="text-5xl opacity-30 select-none transition-transform duration-300 group-hover:scale-110"
            aria-hidden="true"
          >
            {emoji}
          </span>
        </div>
      )
    }

    <!-- 分类徽章（只显示叶子分类） -->
    <span class="absolute top-3 left-3 rounded-full px-2.5 py-0.5 text-xs font-medium
                 bg-void-900/70 backdrop-blur-sm text-sakura-300 border border-sakura-700/40">
      {leaf}
    </span>
  </div>

  <!-- ── 文字区域 ─────────────────────────────────────── -->
  <div class="p-5 flex flex-col gap-2.5">
    <h2 class="font-heading font-semibold text-base text-lavender-100 line-clamp-2
               group-hover:text-sakura-300 transition-colors duration-200 leading-snug">
      <!--
        after:absolute after:inset-0 让整个卡片区域都是链接的点击热区，
        同时 <a> 的文字仍是无障碍的可读标题。
      -->
      <a href={`/blog/${slug}`} class="after:absolute after:inset-0">
        {title}
      </a>
    </h2>

    <p class="text-lavender-400 text-sm line-clamp-2 leading-relaxed">{description}</p>

    <div class="flex items-center justify-between mt-auto pt-2.5 border-t border-white/6">
      <time
        datetime={pubDate.toISOString()}
        class="text-xs text-lavender-600"
      >
        {dateStr}
      </time>

      <!--
        最多展示 3 个标签 —— 做成真链接到 /tags/{tag}：
         - relative z-10 抬到 `<h2> <a after:absolute after:inset-0>` 的全卡片 overlay
           之上，否则 tag-pill 的 hover 态会被 overlay 吃掉；同时让点击直接走到标签页，
           不会先触发整卡卡片的 post 跳转。
         - cursor-pointer 在 .tag-pill 里原本就有，现在终于名副其实。
      -->
      <div class="relative z-10 flex flex-wrap gap-1" aria-label="文章标签">
        {tags.slice(0, LIMITS.postCardTags).map((tag) => (
          <a href={`/tags/${encodeURIComponent(tag)}`} class="tag-pill">{tag}</a>
        ))}
      </div>
    </div>
  </div>
</article>
