---
/**
 * @page 404
 * @description 自定义 404 页。Astro 构建时输出到 dist/404.html，
 *              由 nginx.conf 的 `error_page 404 /404.html;` 消费。
 *
 * 视觉与首页视频开屏风格一致：粒子背景 + 中央玻璃态卡片 + 返回链接。
 */

import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';
---

<Layout title="页面走丢了" description={`在 ${SITE.name} 上没有找到这个页面`}>
  <section
    class="relative z-10 flex flex-col items-center justify-center
           min-h-[calc(100dvh-4rem)] px-6 text-center"
  >
    <div class="glass-card px-10 py-12 sm:px-14 sm:py-16 max-w-lg reveal">
      <!--
        "404" 是纯阿拉伯数字 —— 正好吃 font-display（Fraunces）的 opsz 144 +
        SOFT 50 档位，超大字形时笔画会自然变粗、转角变软，比 font-heading
        的楷书回退要更贴 HANDOFF 的 display 意图
      -->
      <p
        class="font-display text-7xl sm:text-8xl font-medium text-gradient
               leading-none mb-4 tracking-tight"
        style="font-variation-settings: 'opsz' 144, 'SOFT' 50;"
        aria-hidden="true"
      >
        404
      </p>
      <h1 class="font-heading text-2xl sm:text-3xl font-bold text-lavender-100 mb-3">页面走丢了</h1>
      <p class="text-sm text-lavender-400 leading-relaxed mb-8">
        你要找的内容可能已经被移动、删除，或者从来没有存在过。<br />
        不妨回到首页，或从文章列表里看看有什么感兴趣的。
      </p>

      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-medium
                 bg-gradient-to-r from-sakura-500 to-sakura-400 text-white
                 hover:shadow-glow-pink transition-shadow duration-200"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="m15 18-6-6 6-6"></path>
          </svg>
          返回首页
        </a>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-medium
                 text-lavender-300 border border-white/10
                 hover:text-sakura-400 hover:border-sakura-500/40 transition-colors duration-200"
        >
          浏览文章
        </a>
      </div>
    </div>
  </section>
</Layout>
