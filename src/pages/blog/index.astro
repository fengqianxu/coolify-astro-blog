---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import Sidebar from '../../components/Sidebar.astro';

const allPosts = (await getCollection('posts', p => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tagCounts: Record<string, number> = {};
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}
const allTags = Object.keys(tagCounts).sort((a, b) => tagCounts[b]! - tagCounts[a]!);

const categories: Record<string, number> = {};
for (const post of allPosts) {
  const cat = post.data.category;
  categories[cat] = (categories[cat] ?? 0) + 1;
}
---

<Layout title="文章" description="所有文章列表">
  <div class="relative z-10 max-w-5xl mx-auto px-6 pb-16">

    <div class="mb-8">
      <h1 class="font-heading text-3xl font-bold text-gradient mb-2">全部文章</h1>
      <p class="text-slate-400 text-sm">共 {allPosts.length} 篇</p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      <section class="flex-1 min-w-0">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {allPosts.map((post, i) => (
            <div class="animate-slide-up" style={`animation-delay:${i * 50}ms;animation-fill-mode:both`}>
              <PostCard
                slug={post.slug}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                category={post.data.category}
                heroImage={post.data.heroImage}
              />
            </div>
          ))}
        </div>
      </section>

      <Sidebar
        allTags={allTags}
        tagCounts={tagCounts}
        recentPosts={allPosts.slice(0, 5).map(p => ({
          slug: p.slug, title: p.data.title, pubDate: p.data.pubDate,
        }))}
        categories={categories}
      />
    </div>
  </div>
</Layout>
