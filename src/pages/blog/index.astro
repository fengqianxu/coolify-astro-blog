---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getSiteStats } from '../../utils/stats';
import { LIMITS } from '../../config/site';

// 统计走同一个 source，保证和 about 页、首页 sidebar 口径完全一致
const { allPosts, totalPosts, allTags, tagCounts, categoriesByTopLevel } =
  await getSiteStats();
---

<Layout title="文章" description="所有文章列表">
  <div class="relative z-10 max-w-5xl mx-auto px-6 pb-16">

    <div class="mb-8">
      <h1 class="font-heading text-3xl font-bold text-gradient mb-2">全部文章</h1>
      <p class="text-slate-400 text-sm">共 {totalPosts} 篇</p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      <section class="flex-1 min-w-0">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {allPosts.map((post, i) => (
            // animation-delay 对 i 封顶：文章多时不想看到最后一张还在等 5 秒才浮现。
            <div class="animate-slide-up" style={`animation-delay:${Math.min(i, 10) * 50}ms;animation-fill-mode:both`}>
              <PostCard
                slug={post.slug}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                category={post.data.category}
                heroImage={post.data.heroImage}
              />
            </div>
          ))}
        </div>
      </section>

      <Sidebar
        allTags={allTags}
        tagCounts={tagCounts}
        totalPosts={totalPosts}
        recentPosts={allPosts.slice(0, LIMITS.sidebarRecent).map(p => ({
          slug: p.slug, title: p.data.title, pubDate: p.data.pubDate,
        }))}
        categories={categoriesByTopLevel}
      />
    </div>
  </div>
</Layout>
