---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import Sidebar from '../components/Sidebar.astro';

const allPosts = (await getCollection('posts', p => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured    = allPosts.find(p => p.data.featured);
const recentPosts = allPosts.slice(0, 8);

// Tag counts
const tagCounts: Record<string, number> = {};
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}
const allTags = Object.keys(tagCounts).sort((a, b) => tagCounts[b]! - tagCounts[a]!);

// Category counts
const categories: Record<string, number> = {};
for (const post of allPosts) {
  const cat = post.data.category;
  categories[cat] = (categories[cat] ?? 0) + 1;
}
---

<Layout title="AniLog">

  <!-- ── Hero ─────────────────────────────────────── -->
  <section class="relative z-10 px-6 pt-4 pb-16 max-w-5xl mx-auto text-center">
    <div class="animate-fade-in">
      <div class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 mb-6
                  bg-sakura-500/10 border border-sakura-500/25 text-sakura-300 text-sm">
        <span class="animate-twinkle">✨</span>
        <span>欢迎来到我的小站</span>
      </div>

      <h1 class="font-heading text-5xl sm:text-7xl font-bold mb-4 leading-tight">
        <span class="text-gradient">AniLog</span>
      </h1>

      <p class="text-slate-400 text-lg sm:text-xl max-w-xl mx-auto leading-relaxed mb-8">
        记录技术成长，分享二次元热情<br/>
        <span class="text-slate-500 text-base">用代码描绘属于自己的故事</span>
      </p>

      <div class="flex items-center justify-center gap-4 flex-wrap">
        <a href="/blog"
           class="px-6 py-2.5 rounded-xl font-medium text-sm text-white
                  bg-gradient-to-r from-sakura-600 to-cosmic-600
                  hover:shadow-sakura-glow hover:scale-105
                  transition-all duration-300">
          开始阅读
        </a>
        <a href="/about"
           class="px-6 py-2.5 rounded-xl font-medium text-sm text-slate-300
                  border border-white/10 hover:border-sakura-500/40 hover:text-white
                  transition-all duration-300">
          关于我
        </a>
      </div>
    </div>

    <!-- Decorative orbs -->
    <div class="pointer-events-none select-none absolute -top-10 -left-10 w-64 h-64 rounded-full
                bg-sakura-500/10 blur-3xl" aria-hidden="true"></div>
    <div class="pointer-events-none select-none absolute -bottom-10 -right-10 w-80 h-80 rounded-full
                bg-cosmic-600/10 blur-3xl" aria-hidden="true"></div>
  </section>

  <!-- ── Main content ──────────────────────────────── -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 pb-16">
    <div class="flex flex-col lg:flex-row gap-8">

      <!-- Post grid -->
      <section class="flex-1 min-w-0">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-1 h-6 rounded-full bg-gradient-sakura"></span>
          <h2 class="font-heading font-semibold text-slate-200">最新文章</h2>
          <a href="/blog" class="ml-auto text-xs text-sakura-400 hover:text-sakura-300 transition-colors">
            查看全部 →
          </a>
        </div>

        {recentPosts.length === 0 ? (
          <div class="glass-card p-12 text-center text-slate-500">
            <p class="text-4xl mb-3">📝</p>
            <p>还没有文章，快来发布第一篇吧！</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 relative">
            {recentPosts.map((post, i) => (
              <div class="animate-slide-up" style={`animation-delay:${i * 60}ms;animation-fill-mode:both`}>
                <PostCard
                  slug={post.slug}
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  tags={post.data.tags}
                  category={post.data.category}
                  heroImage={post.data.heroImage}
                  featured={post.data.featured}
                />
              </div>
            ))}
          </div>
        )}
      </section>

      <!-- Sidebar -->
      <Sidebar
        allTags={allTags}
        tagCounts={tagCounts}
        recentPosts={allPosts.slice(0, 5).map(p => ({
          slug: p.slug, title: p.data.title, pubDate: p.data.pubDate,
        }))}
        categories={categories}
      />
    </div>
  </div>
</Layout>
