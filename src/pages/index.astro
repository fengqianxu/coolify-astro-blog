---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import HeroVideo from '../components/HeroVideo.astro';
import PostCard from '../components/PostCard.astro';
import Sidebar from '../components/Sidebar.astro';

const allPosts = (await getCollection('posts', p => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recentPosts = allPosts.slice(0, 8);

const tagCounts: Record<string, number> = {};
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}
const allTags = Object.keys(tagCounts).sort((a, b) => tagCounts[b]! - tagCounts[a]!);

const categories: Record<string, number> = {};
for (const post of allPosts) {
  const cat = post.data.category;
  categories[cat] = (categories[cat] ?? 0) + 1;
}
---

<!-- heroVideo=true → no top spacer, nav starts transparent over video -->
<Layout title="AniLog" heroVideo={true}>

  <!-- ── 1. Fullscreen video splash ────────────────── -->
  <HeroVideo />

  <!-- ── 2. Blog content (revealed on scroll) ──────── -->
  <div id="main-content" class="relative z-10">

    <!-- Section title strip -->
    <div class="max-w-5xl mx-auto px-6 pt-14 pb-6">
      <div class="flex items-center gap-3">
        <span class="w-1 h-6 rounded-full bg-gradient-kawaii shrink-0"></span>
        <h2 class="font-heading font-semibold text-purple-900 text-xl">最新文章</h2>
        <a href="/blog" class="ml-auto text-xs text-sakura-500 hover:text-sakura-600 transition-colors font-medium">
          查看全部 →
        </a>
      </div>
    </div>

    <!-- Posts + Sidebar -->
    <div class="max-w-5xl mx-auto px-6 pb-20">
      <div class="flex flex-col lg:flex-row gap-8">

        <section class="flex-1 min-w-0">
          {recentPosts.length === 0 ? (
            <div class="glass-card p-12 text-center text-purple-400">
              <p class="text-4xl mb-3">📝</p>
              <p>还没有文章，快来发布第一篇吧！</p>
            </div>
          ) : (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              {recentPosts.map((post, i) => (
                <div class="animate-slide-up" style={`animation-delay:${i * 60}ms;animation-fill-mode:both`}>
                  <PostCard
                    slug={post.slug}
                    title={post.data.title}
                    description={post.data.description}
                    pubDate={post.data.pubDate}
                    tags={post.data.tags}
                    category={post.data.category}
                    heroImage={post.data.heroImage}
                    featured={post.data.featured}
                  />
                </div>
              ))}
            </div>
          )}
        </section>

        <Sidebar
          allTags={allTags}
          tagCounts={tagCounts}
          recentPosts={allPosts.slice(0, 5).map(p => ({
            slug: p.slug, title: p.data.title, pubDate: p.data.pubDate,
          }))}
          categories={categories}
        />
      </div>
    </div>
  </div>

</Layout>
