---
/**
 * @page 首页
 * @description 全屏视频开屏 → 滚动进入最新文章网格 + 侧边栏。
 */

import { getCollection } from 'astro:content';
import Layout    from '../layouts/Layout.astro';
import HeroVideo from '../components/HeroVideo.astro';
import PostCard  from '../components/PostCard.astro';
import Sidebar   from '../components/Sidebar.astro';
import type { SidebarData } from '../types';
import { catLeaf } from '../utils/category';

// ── 数据聚合 ─────────────────────────────────────────────────────────
const allPosts = (await getCollection('posts', (p) => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 标签计数
const tagCounts: Record<string, number> = {};
for (const { data } of allPosts) {
  for (const tag of data.tags) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}
const allTags = Object.keys(tagCounts).sort((a, b) => tagCounts[b]! - tagCounts[a]!);

// 分类计数（侧边栏按「叶子」聚合，最具体的那一层）
const categories: Record<string, number> = {};
for (const { data } of allPosts) {
  const leaf = catLeaf(data);
  categories[leaf] = (categories[leaf] ?? 0) + 1;
}

const sidebarData: SidebarData = {
  allTags,
  tagCounts,
  recentPosts: allPosts.slice(0, 5).map((p) => ({
    slug:    p.slug,
    title:   p.data.title,
    pubDate: p.data.pubDate,
  })),
  categories,
};
---

<Layout title="AniLog" heroVideo={true}>

  <!-- 全屏视频开屏（100dvh） -->
  <HeroVideo />

  <!-- 正文区（滚动后呈现） -->
  <div id="main-content" class="relative z-10 max-w-5xl mx-auto px-6 pb-20">

    <!-- 区块标题 -->
    <div class="section-heading pt-14 mb-6">
      <h2 class="font-heading font-semibold text-lavender-200 text-xl">最新文章</h2>
      <a href="/blog"
         class="ml-auto text-xs text-sakura-400 hover:text-sakura-300
                transition-colors font-medium">
        查看全部 →
      </a>
    </div>

    <!-- 文章网格 + 侧边栏 -->
    <div class="flex flex-col lg:flex-row gap-8">

      <!-- 文章网格 -->
      <section class="flex-1 min-w-0" aria-label="最新文章列表">
        {allPosts.length === 0
          ? (
            <div class="glass-card p-12 text-center text-lavender-500">
              <p class="text-4xl mb-3" aria-hidden="true">📝</p>
              <p>还没有文章，快来发布第一篇吧！</p>
            </div>
          )
          : (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              {allPosts.slice(0, 8).map((post, i) => (
                <div
                  class="animate-slide-up"
                  style={`animation-delay: ${i * 60}ms`}
                >
                  <PostCard
                    slug={post.slug}
                    title={post.data.title}
                    description={post.data.description}
                    pubDate={post.data.pubDate}
                    tags={post.data.tags}
                    category={post.data.category}
                    heroImage={post.data.heroImage}
                    featured={post.data.featured}
                  />
                </div>
              ))}
            </div>
          )
        }
      </section>

      <Sidebar {...sidebarData} />
    </div>
  </div>

</Layout>
