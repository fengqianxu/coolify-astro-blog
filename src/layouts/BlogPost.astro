---
/**
 * @layout BlogPost
 * @description 文章详情页布局。
 *
 * 包含：封面图、元数据头（标题/标签/日期）、Markdown 正文、返回链接。
 * 阅读进度条由父 Layout 的全局脚本驱动，无需在此处理。
 */

import Layout from './Layout.astro';
import type { PostMeta } from '../types';
import { fmtLong } from '../utils/date';
import { SITE } from '../config/site';

// 只需 PostMeta 的子集，不含 draft/featured
type Props = Omit<PostMeta, 'draft' | 'featured'>;

const { title, description, pubDate, updatedDate, heroImage, tags, category } = Astro.props;

const dateStr    = fmtLong(pubDate);
const updatedStr = updatedDate ? fmtLong(updatedDate) : undefined;

// JSON-LD Article schema，帮 Google 把文章页当「文章」而不是普通 web 页
const siteBase = Astro.site ?? new URL(`${SITE.url}/`);
const pageUrl  = new URL(Astro.url.pathname, siteBase).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type':   'BlogPosting',
  headline:  title,
  description,
  image:     heroImage ? new URL(heroImage, siteBase).toString() : undefined,
  datePublished: pubDate.toISOString(),
  dateModified:  (updatedDate ?? pubDate).toISOString(),
  author:   { '@type': 'Person',       name: SITE.author },
  publisher:{ '@type': 'Organization', name: SITE.name   },
  keywords: tags.join(', '),
  articleSection: category.join(' / '),
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  url: pageUrl,
};
---

<Layout title={title} description={description} ogImage={heroImage} ogType="article">
  <!-- 结构化数据：搜索引擎解析 body 内 JSON-LD 同样有效 -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <article class="relative z-10 max-w-3xl mx-auto px-6 pb-24">

    <!-- 封面图 -->
    {heroImage && (
      <div class="rounded-3xl overflow-hidden mb-8 aspect-video shadow-card">
        <img
          src={heroImage}
          alt={`${title} 封面图`}
          class="w-full h-full object-cover"
          width="1600"
          height="900"
          loading="eager"
          decoding="async"
        />
      </div>
    )}

    <!-- 元数据头 -->
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <!-- 分类路径面包屑（考试 / 申论 / 大作文） -->
        <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-medium
                     bg-sakura-500/15 text-sakura-300 border border-sakura-700/40">
          {category.map((seg, i) => (
            <>
              {i > 0 && <span class="text-sakura-500/60">/</span>}
              <span>{seg}</span>
            </>
          ))}
        </span>
        {tags.map((tag) => (
          <a href={`/tags/${encodeURIComponent(tag)}`} class="tag-pill">{tag}</a>
        ))}
      </div>

      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-lavender-100
                 leading-tight mb-4">
        {title}
      </h1>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-lavender-500">
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        {updatedStr && (
          <span class="text-lavender-600">· 更新于 {updatedStr}</span>
        )}
      </div>
    </header>

    <!-- Markdown 正文（prose-twilight 来自 tailwind.config.mjs typography 扩展） -->
    <div class="glass-card p-8 sm:p-10
                prose prose-twilight max-w-none
                prose-headings:font-heading
                prose-a:no-underline prose-a:text-sakura-400 hover:prose-a:text-sakura-300
                prose-code:before:content-none prose-code:after:content-none
                prose-pre:rounded-2xl prose-pre:border prose-pre:border-white/8
                prose-blockquote:bg-sakura-500/5 prose-blockquote:rounded-r-xl prose-blockquote:py-1
                prose-img:rounded-2xl prose-img:shadow-card">
      <slot />
    </div>

    <!-- 返回链接 -->
    <div class="mt-10 pt-6 border-t border-white/6">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm text-lavender-500
               hover:text-sakura-400 transition-colors duration-200"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"
             viewBox="0 0 24 24" aria-hidden="true">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        返回文章列表
      </a>
    </div>

  </article>
</Layout>
