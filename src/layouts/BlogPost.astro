---
import Layout from './Layout.astro';

interface Props {
  title:        string;
  description:  string;
  pubDate:      Date;
  updatedDate?: Date;
  heroImage?:   string;
  tags:         string[];
  category:     string;
}

const { title, description, pubDate, updatedDate, heroImage, tags, category } = Astro.props;

const dateStr    = pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedStr = updatedDate?.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={title} description={description} ogImage={heroImage}>
  <article class="relative z-10 max-w-3xl mx-auto px-6 pb-20">

    {heroImage && (
      <div class="rounded-3xl overflow-hidden mb-8 aspect-video shadow-md">
        <img src={heroImage} alt={title} class="w-full h-full object-cover" />
      </div>
    )}

    <header class="mb-8">
      <div class="flex items-center gap-2 mb-4 flex-wrap">
        <span class="rounded-full px-3 py-0.5 text-xs font-medium
                     bg-sakura-100 text-sakura-600 border border-sakura-200">{category}</span>
        {tags.map(tag => <span class="tag-pill">{tag}</span>)}
      </div>

      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-purple-950 leading-tight mb-4">
        {title}
      </h1>

      <div class="flex items-center gap-4 text-sm text-purple-400">
        <time>{dateStr}</time>
        {updatedStr && <span>· 更新于 {updatedStr}</span>}
      </div>
    </header>

    <!-- Article body -->
    <div class="glass-card p-8 sm:p-10 prose prose-kawaii max-w-none
                prose-headings:font-heading
                prose-a:no-underline prose-a:text-sakura-500 hover:prose-a:text-sakura-600
                prose-code:before:content-none prose-code:after:content-none
                prose-pre:rounded-2xl prose-pre:border prose-pre:border-sakura-100 prose-pre:shadow-sm
                prose-blockquote:border-l-sakura-400 prose-blockquote:bg-sakura-50/60 prose-blockquote:rounded-r-xl prose-blockquote:py-1
                prose-img:rounded-2xl prose-img:shadow-md">
      <slot />
    </div>

    <div class="mt-10 pt-6 border-t border-sakura-100">
      <a href="/blog" class="inline-flex items-center gap-2 text-sm text-purple-500 hover:text-sakura-500 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        返回文章列表
      </a>
    </div>

  </article>
</Layout>
