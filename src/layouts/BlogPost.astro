---
import Layout from './Layout.astro';

interface Props {
  title:       string;
  description: string;
  pubDate:     Date;
  updatedDate?: Date;
  heroImage?:  string;
  tags:        string[];
  category:    string;
}

const { title, description, pubDate, updatedDate, heroImage, tags, category } = Astro.props;

const dateStr = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const updatedStr = updatedDate?.toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<Layout title={title} description={description} ogImage={heroImage}>
  <article class="relative z-10 max-w-3xl mx-auto px-6 pb-20">

    <!-- Hero image -->
    {heroImage && (
      <div class="rounded-2xl overflow-hidden mb-8 aspect-video">
        <img src={heroImage} alt={title} class="w-full h-full object-cover" />
      </div>
    )}

    <!-- Meta -->
    <header class="mb-8">
      <div class="flex items-center gap-2 mb-4">
        <span class="tag-pill">{category}</span>
        {tags.map(tag => <span class="tag-pill">{tag}</span>)}
      </div>

      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-white leading-tight mb-4">
        {title}
      </h1>

      <div class="flex items-center gap-4 text-sm text-slate-500">
        <time>{dateStr}</time>
        {updatedStr && <span>· 更新于 {updatedStr}</span>}
      </div>
    </header>

    <!-- Body -->
    <div class="prose prose-anime prose-invert max-w-none
                prose-headings:font-heading
                prose-a:no-underline prose-a:text-sakura-400 hover:prose-a:text-sakura-300
                prose-code:before:content-none prose-code:after:content-none
                prose-pre:rounded-2xl prose-pre:border prose-pre:border-white/[0.08]
                prose-blockquote:border-l-sakura-500 prose-blockquote:bg-sakura-500/5 prose-blockquote:rounded-r-xl prose-blockquote:py-1">
      <slot />
    </div>

    <!-- Back link -->
    <div class="mt-12 pt-6 border-t border-white/[0.06]">
      <a href="/blog" class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-sakura-300 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        返回文章列表
      </a>
    </div>

  </article>
</Layout>
