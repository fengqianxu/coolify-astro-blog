---
/**
 * @layout Layout
 * @description 全站基础布局。每个页面都应包裹在此组件中。
 *
 * 职责：
 *  - 注入全局 CSS、字体、meta 标签
 *  - 渲染固定导航栏（NavBar）
 *  - 渲染粒子背景（StarField）
 *  - 渲染全局搜索弹窗（SearchModal）
 *  - 管理阅读进度条
 *
 * @prop title       页面标题（不含站名后缀）
 * @prop description 页面描述（默认读取 SITE.description）
 * @prop ogImage     OG 图片路径
 * @prop heroVideo   true = 页面顶部有全屏视频，隐藏顶部间距且导航栏初始透明
 */

import '../styles/global.css';
import { SITE } from '../config/site';
import NavBar      from '../components/NavBar.astro';
import Footer      from '../components/Footer.astro';
import StarField   from '../components/StarField.astro';
import SearchModal from '../components/SearchModal.astro';

interface Props {
  title:        string;
  description?: string;
  ogImage?:     string;
  heroVideo?:   boolean;
}

const {
  title,
  description = SITE.description,
  ogImage     = '/og-default.png',
  heroVideo   = false,
} = Astro.props;

// 页面 <title>：首页直接使用站名，其他页面加后缀
const fullTitle = title === SITE.name ? SITE.name : `${title} · ${SITE.name}`;
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <!-- Open Graph -->
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:type"        content="website" />
    <!-- PWA / Browser Chrome -->
    <meta name="theme-color" content={SITE.themeColor} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <!--
      主题恢复（防 FOUC）：必须在 <body> 渲染前同步执行。
      优先级：
        1. 用户手动切换过 → 遵守 localStorage['theme'] ('light' | 'dark')
        2. 没设置过 → 按本地时间：06:00–18:00 亮色，其余时段暗色
    -->
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        let isDark;
        if (saved === 'dark' || saved === 'light') {
          isDark = saved === 'dark';
        } else {
          const h = new Date().getHours();
          isDark = h < 6 || h >= 18;
        }
        if (isDark) document.documentElement.classList.add('dark');
      })();
    </script>
  </head>

  <body class="min-h-dvh flex flex-col">
    <!-- 阅读进度条（仅文章页有意义，其他页不可见） -->
    <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

    <!-- 粒子背景（花瓣 + 闪光） -->
    <StarField />

    <!-- 全局搜索弹窗（挂载一次） -->
    <SearchModal />

    <!-- 固定导航栏 -->
    <NavBar heroVideo={heroVideo} />

    <!--
      非视频首屏：推开导航栏高度（var(--nav-height)）
      视频首屏：HeroVideo 自身占满视口，不需要额外间距
    -->
    {!heroVideo && <div class="h-16" aria-hidden="true"></div>}

    <main class="flex-1">
      <slot />
    </main>

    <Footer />

    <script>
      // 阅读进度条：基于文档总可滚动高度计算百分比
      const progressBar = document.getElementById('reading-progress');
      if (progressBar) {
        const updateProgress = () => {
          const { scrollTop, scrollHeight, clientHeight } = document.documentElement;
          const scrollable = scrollHeight - clientHeight;
          const pct = scrollable > 0 ? (scrollTop / scrollable) * 100 : 0;
          progressBar.style.setProperty('--reading-progress', `${Math.min(pct, 100)}%`);
        };
        window.addEventListener('scroll', updateProgress, { passive: true });
      }
    </script>
  </body>
</html>
