---
/**
 * @layout Layout
 * @description 全站基础布局。每个页面都应包裹在此组件中。
 *
 * 职责：
 *  - 注入全局 CSS、字体、meta 标签
 *  - 渲染固定导航栏（NavBar）
 *  - 渲染粒子背景（StarField）
 *  - 渲染全局搜索弹窗（SearchModal）
 *  - 管理阅读进度条
 *
 * @prop title       页面标题（不含站名后缀）
 * @prop description 页面描述（默认读取 SITE.description）
 * @prop ogImage     OG 图片路径
 * @prop heroVideo   true = 页面顶部有全屏视频，隐藏顶部间距且导航栏初始透明
 */

import '../styles/global.css';
import { SITE } from '../config/site';
import NavBar      from '../components/NavBar.astro';
import Footer      from '../components/Footer.astro';
import StarField   from '../components/StarField.astro';
import SearchModal from '../components/SearchModal.astro';

interface Props {
  title:        string;
  description?: string;
  ogImage?:     string;
  heroVideo?:   boolean;
  /** 指定页面类型，用于 OG 区分 website / article */
  ogType?:      'website' | 'article';
}

const {
  title,
  description = SITE.description,
  ogImage     = '/og-default.png',
  heroVideo   = false,
  ogType      = 'website',
} = Astro.props;

// 页面 <title>：首页直接使用站名，其他页面加后缀
const fullTitle = title === SITE.name ? SITE.name : `${title} · ${SITE.name}`;

// canonical & 绝对 URL（site 未配置时退化为相对 URL）
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? `${SITE.url}/`).toString();
const absOgImage   = new URL(ogImage, Astro.site ?? `${SITE.url}/`).toString();
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={absOgImage} />
    <meta property="og:type"        content={ogType} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:site_name"   content={SITE.name} />
    <meta property="og:locale"      content={SITE.locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={absOgImage} />

    <!-- PWA / Browser Chrome -->
    <meta name="theme-color" content={SITE.themeColor} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href="/rss.xml" />

    <!--
      字体：
        - LXGW WenKai（标题）/ Screen（正文）：jsDelivr CDN 手写楷书
        - JetBrains Mono（font-mono 代码字体）：Google Fonts
      全部走 <link>，避免在 global.css 里 @import 阻塞样式解析。
    -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/style.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-screen-webfont@1.7.0/style.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" />

    <title>{fullTitle}</title>

    <!--
      主题恢复（防 FOUC）：必须在 <body> 渲染前同步执行。
      优先级：
        1. 用户手动切换过 → 遵守 localStorage['theme'] ('light' | 'dark')
        2. 没设置过 → 按本地时间：06:00–18:00 亮色，其余时段暗色
    -->
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        let isDark;
        if (saved === 'dark' || saved === 'light') {
          isDark = saved === 'dark';
        } else {
          const h = new Date().getHours();
          isDark = h < 6 || h >= 18;
        }
        if (isDark) document.documentElement.classList.add('dark');
      })();
    </script>
  </head>

  <body class="min-h-dvh flex flex-col">
    {/* 阅读进度条：仅文章页挂载，列表/归档/关于这些页面完全不渲染元素 + 不绑定 scroll */}
    {ogType === 'article' && (
      <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>
    )}

    <!-- 粒子背景（花瓣 + 闪光） -->
    <StarField />

    <!-- 全局搜索弹窗（挂载一次） -->
    <SearchModal />

    <!-- 固定导航栏 -->
    <NavBar heroVideo={heroVideo} />

    <!--
      非视频首屏：推开导航栏高度（var(--nav-height)）
      视频首屏：HeroVideo 自身占满视口，不需要额外间距
    -->
    {!heroVideo && <div class="h-16" aria-hidden="true"></div>}

    <main class="flex-1">
      <slot />
    </main>

    <Footer />

    <script>
      // 阅读进度条：基于文档总可滚动高度计算百分比。
      //   - 仅文章页会渲染 #reading-progress 元素，列表页 getElementById 拿到 null 直接跳过
      //   - rAF 节流：滚动事件可能很密，合并到下一帧计算一次就够
      const progressBar = document.getElementById('reading-progress');
      if (progressBar) {
        let pending = false;
        const updateProgress = () => {
          const { scrollTop, scrollHeight, clientHeight } = document.documentElement;
          const scrollable = scrollHeight - clientHeight;
          const pct = scrollable > 0 ? (scrollTop / scrollable) * 100 : 0;
          progressBar.style.setProperty('--reading-progress', `${Math.min(pct, 100)}%`);
          pending = false;
        };
        window.addEventListener('scroll', () => {
          if (pending) return;
          pending = true;
          requestAnimationFrame(updateProgress);
        }, { passive: true });
      }
    </script>
  </body>
</html>
