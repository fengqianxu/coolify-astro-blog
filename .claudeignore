# Claude Code 读取忽略 —— 仅用于减少无关文件占用上下文，
# 并不等同于 .gitignore。注释开头，详见每一段说明。

# ── 构建产物 / 依赖 ───────────────────────────────────
node_modules/
dist/
.astro/
package-lock.json

# ── 系统 / 编辑器杂文件 ──────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.log

# ── 环境变量 / 敏感文件（永远不读） ───────────────────
.env
.env.*
!.env.example

# ── 本地素材与第三方参考 ──────────────────────────────
# assets/ 是本地原始素材、博客源代码参考/ 是第三方模板对照，
# 两者都不进仓、也不需要 Claude 改；公开 public/ 保留（要读 robots.txt/OG/favicon）
assets/
博客源代码参考/

# ── 大二进制：视频/字体/图片 ─────────────────────────
# Claude 无法直接理解这些媒体文件；读取只会占 token
public/videos/
*.mp4
*.webm
*.woff
*.woff2
*.ttf
*.otf
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
# 例外：站点图标 / 头像 / 默认 OG 如需查看可临时注释上面两行

# ── Claude 本地调试配置 ───────────────────────────────
.claude/
