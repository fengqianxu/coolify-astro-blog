{
  "name": "heltlog",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "type-check": "astro check",
    "lint": "eslint \"src/**/*.{ts,tsx,js,astro}\" \"*.{mjs,cjs,js}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,astro,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,astro,json,css}\"",
    "verify": "astro check && astro build",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/rss": "^4.0.0",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^5.1.0",
    "@tailwindcss/typography": "^0.5.15",
    "astro": "^5.0.0",
    "rehype-pretty-code": "^0.14.0",
    "shiki": "^1.0.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "yaml": "^2.8.3"
  }
}
